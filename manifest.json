{
  "manifest_version": 3,
  "name": "HN Comment Quality Detector",
  "version": "1.5.0",
  "description": "A privacy-first, Gemini-powered signal vs. noise layer for Hacker News.",
  "permissions": [
    "storage",
    "aiLanguageModel"
  ],
  "host_permissions": [
    "https://news.ycombinator.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://news.ycombinator.com/item?id=*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ]
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}